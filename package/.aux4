{
  "scope": "aux4",
  "name": "api",
  "version": "0.1.2",
  "description": "aux4 API",
  "license": "Apache-2.0",
  "tags": [
    "api",
    "aux4"
  ],
  "dependencies": [
    "aux4/config"
  ],
  "system": [
    ["test:node --version", "brew:node", "linux:nodejs"]
  ],
  "profiles": [
    {
      "name": "main",
      "commands": [
        {
          "name": "api",
          "execute": [
            "profile:api"
          ],
          "help": {
            "text": "aux4 API"
          }
        }
      ]
    },
    {
      "name": "api",
      "commands": [
        {
          "name": "start",
          "execute": [
            "node ${packageDir}/lib/server.js start values(port, cors, api, ws, server, tls)"
          ],
          "help": {
            "text": "Start the aux4 API server",
            "variables": [
              {
                "name": "port",
                "text": "The port to run the API server on",
                "default": "9876",
                "env": "AUX4_API_PORT"
              },
              {
                "name": "cors",
                "text": "CORS configuration for the API server",
                "default": ""
              },
              {
                "name": "api",
                "text": "The endpoint mapping for the API",
                "default": ""
              },
              {
                "name": "ws",
                "text": "The WebSocket route configuration",
                "default": ""
              },
              {
                "name": "server",
                "text": "Server configuration including file upload limits",
                "default": ""
              },
              {
                "name": "tls",
                "text": "TLS configuration with key and cert file paths",
                "default": ""
              }
            ]
          }
        },
        {
          "name": "stop",
          "execute": [
            "node ${packageDir}/lib/server.js stop"
          ],
          "help": {
            "text": "Stop the aux4 API server"
          }
        }
      ]
    }
  ]
}
